APP_NAME=VOICE
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- DATABASE CONFIGURATION ---
# For Local Development (Docker):
# DB_CONNECTION=mysql
# DB_HOST=mysql
# DB_PORT=3306
# DB_DATABASE=voice_db
# DB_USERNAME=voice_user
# DB_PASSWORD=dbpassword

# For Production (TiDB Cloud - Permanent Free):
DB_CONNECTION=mysql
DB_HOST=REPLACE_WITH_TIDB_ENDPOINT
DB_PORT=4000
DB_DATABASE=test
DB_USERNAME=REPLACE_WITH_TIDB_USERNAME
DB_PASSWORD=REPLACE_WITH_TIDB_PASSWORD
DB_SSL_CA=/etc/ssl/certs/ca-certificates.crt

# --- BROADCASTING (WebSockets) ---
BROADCAST_DRIVER=reverb
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

# --- MAIL CONFIGURATION ---
MAIL_MAILER=log
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
